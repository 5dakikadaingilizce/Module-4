  { "id": 216, "tr": "Geçen hafta çok kar yağdı. (Fiil)", "en": "It snowed a lot last week." },

  { "id": 217, "tr": "Ses / ...gibi gelmek", "en": "Sound" },
  { "id": 218, "tr": "Müziğin sesi. (İsim)", "en": "The sound of music." },
  { "id": 219, "tr": "Kulağa harika geliyor! (Fiil)", "en": "It sounds great!" },

  { "id": 220, "tr": "Durak / Durmak, Durdurmak", "en": "Stop" },
  { "id": 221, "tr": "Bu son durak. (İsim)", "en": "This is the last stop." },
  { "id": 222, "tr": "Arabamızı durdurdular. (Fiil)", "en": "They stopped our car." },

  { "id": 223, "tr": "Çalışma / Çalışmak", "en": "Study" },
  { "id": 224, "tr": "Memelilerin yaşamı hakkındaki bu çalışmayı sevdim. (İsim)", "en": "I loved this study about the life of mammals." },
  { "id": 225, "tr": "Daha fazla çalışmalısın. (Fiil)", "en": "You should study more." },

  { "id": 226, "tr": "Sürpriz / Sürpriz Yapmak", "en": "Surprise" },
  { "id": 227, "tr": "Bu büyük bir sürpriz. (İsim)", "en": "This is a big surprise." },
  { "id": 228, "tr": "Beni şaşırttılar. (Fiil)", "en": "They surprised me." },

  { "id": 229, "tr": "Konuşma / Konuşmak", "en": "Talk" },
  { "id": 230, "tr": "Bu konuşma bitti. (İsim)", "en": "This talk is over." },
  { "id": 231, "tr": "Konuşmamız gerekiyor. (Fiil)", "en": "We need to talk." },

  { "id": 232, "tr": "Tat / Tadı gelmek", "en": "Taste" },
  { "id": 233, "tr": "Kirazların tadını seviyorum. (İsim)", "en": "I love the taste of the cherries." },
  { "id": 234, "tr": "Tatları harika. (Fiil)", "en": "They taste amazing." },

  { "id": 235, "tr": "Test / Test Etmek", "en": "Test" },
  { "id": 236, "tr": "Bu bizim son testimiz. (İsim)", "en": "This is our last test." },
  { "id": 237, "tr": "Sabrımı test etme. (Fiil)", "en": "Don't test my patience." },

  { "id": 238, "tr": "Zaman / Zaman tutmak", "en": "Time" },
  { "id": 239, "tr": "Vakit nakittir. (İsim)", "en": "Time is money." },
  { "id": 240, "tr": "Koşarken onun zamanını tuttular. (Fiil)", "en": "They timed him while he was running." },

  { "id": 241, "tr": "Bahşiş / Bahşiş Vermek", "en": "Tip" },
  { "id": 242, "tr": "Garsonlar bahşişleriyle geçinirler. (İsim)", "en": "The waiters live on their tips." },
  { "id": 243, "tr": "Garsona her zaman bahşiş vermelisin. (Fiil)", "en": "You must always tip the waiter." },

  { "id": 244, "tr": "Tur / Gezmek, Turlamak", "en": "Tour" },
  { "id": 245, "tr": "Bu turu seviyorum. (İsim)", "en": "I love this tour." },
  { "id": 246, "tr": "Bahçenin etrafında turladılar. (Fiil)", "en": "They toured around the garden." },

  { "id": 247, "tr": "Seyahat / Seyahat Etmek", "en": "Travel" },
  { "id": 248, "tr": "Bu seyahat benim için önemli. (İsim)", "en": "This travel is important for me." },
  { "id": 249, "tr": "Dünyayı gezmek istiyorum. (Fiil)", "en": "I wanna travel around the world." },

  { "id": 250, "tr": "Güven / Güvenmek", "en": "Trust" },
  { "id": 251, "tr": "Güvenime sahipsin. (İsim)", "en": "You have my trust." },
  { "id": 252, "tr": "Sana güveniyorum. (Fiil)", "en": "I trust you." },

  { "id": 253, "tr": "Değer / Değer Vermek", "en": "Value" },
  { "id": 254, "tr": "Bazı geleneksel değerlerimiz yok oluyor. (İsim)", "en": "Some of our traditional values are disappearing." },
  { "id": 255, "tr": "Onunla olan arkadaşlığına değer vermelisin. (Fiil)", "en": "You need to value your friendship with him." },

  { "id": 256, "tr": "Ziyaret / Ziyaret Etmek", "en": "Visit" },
  { "id": 257, "tr": "Bu ziyaret kısaydı. Yine gelin! (İsim)", "en": "This visit was short. Come again!" },
  { "id": 258, "tr": "Bayramda bizi ziyaret ettiler. (Fiil)", "en": "They visited us on Bayram." },

  { "id": 259, "tr": "Oy / Oy Vermek", "en": "Vote" },
  { "id": 260, "tr": "Her bir oy önemlidir. (İsim)", "en": "Each vote is important." },
  { "id": 261, "tr": "Onlara oy vermedim. (Fiil)", "en": "I didn't vote for them." },

  { "id": 262, "tr": "Yürüyüş / Yürümek", "en": "Walk" },
  { "id": 263, "tr": "Bir yürüyüşe ihtiyacım var. (İsim)", "en": "I need a walk." },
  { "id": 264, "tr": "Yürümemiz gerekiyor. (Fiil)", "en": "We need to walk." },

  { "id": 265, "tr": "Su / Sulamak", "en": "Water" },
  { "id": 266, "tr": "Su hayati önem taşır. (İsim)", "en": "Water is vital for humans." },
  { "id": 267, "tr": "Bahçemi suladım. (Fiil)", "en": "I watered my garden." },

  { "id": 268, "tr": "Fısıltı / Fısıldamak", "en": "Whisper" },
  { "id": 269, "tr": "Bir fısıltı duydum. (İsim)", "en": "I heard a whisper." },
  { "id": 270, "tr": "Kulağıma fısıldadı. (Fiil)", "en": "She whispered in my ear." },

  { "id": 271, "tr": "Islık / Islık Çalmak", "en": "Whistle" },
  { "id": 272, "tr": "Köpekler çobanın ıslığını duyabilir. (İsim)", "en": "The dogs can hear the shepherd's whistle." },
  { "id": 273, "tr": "Çoban koyunlarına ıslık çaldı. (Fiil)", "en": "The shepherd whistled at his sheep." },

  { "id": 274, "tr": "Dilek / Dilemek", "en": "Wish" },
  { "id": 275, "tr": "Son dileğin nedir? (İsim)", "en": "What is your last wish?" },
  { "id": 276, "tr": "Doğum günümü kutladılar. (Fiil)", "en": "They wished me a happy birthday." },

  { "id": 277, "tr": "İş / Çalışmak", "en": "Work" },
  { "id": 278, "tr": "Bu ağır bir iş. (İsim)", "en": "This is heavy work." },
  { "id": 279, "tr": "Benim için çalışabilirsin! (Fiil)", "en": "You can work for me!" },

  { "id": 280, "tr": "Endişe / Endişelenmek", "en": "Worry" },
  { "id": 281, "tr": "Endişeye gerek yok!, Önemli değil! (İsim)", "en": "No worries!" },
  { "id": 282, "tr": "Sağlığın için endişeleniyorum. (Fiil)", "en": "I worry about your health." }
]
